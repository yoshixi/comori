# API Configuration
# MAIN_VITE_* variables are used by the main process (CSP configuration)
# VITE_* variables are used by the renderer process (API client, Clerk SDK)

MAIN_VITE_API_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000/api

# Clerk OAuth Configuration
# The publishable key is safe to expose in client-side code
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
