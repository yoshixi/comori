# API Configuration
# MAIN_VITE_* variables are used by the main process (auth flow, CSP configuration)
# VITE_* variables are used by the renderer process (API client)
#
# Note: Clerk credentials are NOT needed here - OAuth is handled by the backend
MAIN_VITE_API_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000/api
