# Production Environment

NODE_ENV=production

# Authentication (required)
BETTER_AUTH_SECRET=your-random-secret-at-least-32-chars
BETTER_AUTH_URL=https://backend.example.com
JWT_SECRET=your-jwt-secret-at-least-32-chars
TRUSTED_ORIGINS=https://app.example.com
# Production app scheme (Expo Go / exp:// URLs are still accepted if they match dev-style hosts — use release builds with techoo:// for real users).
MOBILE_REDIRECT_URIS=techoo://auth-callback,techoo://link-callback

# Google OAuth (required)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://backend.example.com/api/auth/callback/google

# Turso — centralized DB (required)
TURSO_MAIN_DB_URL=libsql://your-main-db-your-org.turso.io
TURSO_MAIN_DB_AUTH_TOKEN=your-turso-auth-token

# Tenanso — per-user tenant databases (required)
TURSO_ORG_SLUG=your-org-slug
TURSO_API_TOKEN=your-turso-api-token
TURSO_GROUP=default
TURSO_GROUP_AUTH_TOKEN=your-group-auth-token
TURSO_SEED_DB_NAME=your-seed-db-name

# Optional
# WEBHOOK_BASE_URL=https://backend.example.com
